        <item name="fontFamily">@font/inter_semi_bold</item>
        <item name="android:textSize">16sp</item>
        <item name="android:letterSpacing">0.001</item>
        <item name="android:lineHeight">22dp</item>
    </style>

    <style name="body_medium">
        <item name="fontFamily">@font/inter_medium</item>
